enum RentalStatus {
  PLACED
  CONFIRMED
  PAID
  PICKED_UP
  RETURNED
  CANCELLED
}

model RentalOrder {
  id                 String       @id @default(uuid())
  customerId         String
  status             RentalStatus @default(PLACED)
  startDate          DateTime
  endDate            DateTime
  totalAmount        Decimal      @db.Decimal(10, 2)
  pickupConfirmedAt  DateTime?
  returnConfirmedAt  DateTime?
  cancelledAt        DateTime?
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  customer User               @relation("CustomerOrders", fields: [customerId], references: [id], onDelete: Cascade)
  items    RentalOrderItem[]
  payments Payment[]
  reviews  Review[]

  @@index([customerId])
  @@map("rental_orders")
}